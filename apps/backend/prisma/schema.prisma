generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth (existing; field names preserved for current auth code) ---

enum UserRole {
  ADMIN
  STAFF
  TECHNICIAN
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  technicianProfile Technician? @relation("TechnicianLinkedUser")
  createdJobs       Job[]       @relation("JobCreatedBy")
  notifications     Notification[]
  notificationPreference NotificationPreference?
  recurringJobTemplates RecurringJobTemplate[]

  @@map("users")
}

// --- Domain enums ---

enum JobStatus {
  NEW
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  INVOICED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum NotificationType {
  JOB_ASSIGNED
  JOB_RESCHEDULED
  JOB_CONFLICT
  INVOICE_DUE
  INVOICE_OVERDUE
  TIME_OFF_CONFLICT
  READY_TO_INVOICE
  DISPATCH_ALERT
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
  DISMISSED
}

enum RecurrencePattern {
  DAILY
  WEEKLY
  MONTHLY
}

model Notification {
  id        String              @id @default(cuid())
  userId    String?
  type      NotificationType
  title     String
  message   String
  payload   Json?
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(PENDING)
  readAt    DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
  @@map("notifications")
}

model NotificationPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  inAppEnabled    Boolean  @default(true)
  emailEnabled    Boolean  @default(false)
  smsEnabled      Boolean  @default(false)
  typePreferences Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// --- Core models (DB columns camelCase to match existing `users` table) ---

model Customer {
  id           String   @id @default(cuid())
  name         String
  email        String?
  phone        String?
  addressLine1 String?
  addressLine2 String?
  suburb       String?
  state        String?
  postcode     String?
  country      String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobs Job[]
  recurringJobTemplates RecurringJobTemplate[]

  @@index([name])
  @@index([email])
  @@map("customers")
}

model Technician {
  id           String   @id @default(cuid())
  name         String
  email        String?
  phone        String?
  /// Skill tags for scheduling / dispatch (PostgreSQL text array).
  skills       String[] @default([])
  /// UI color token or hex for calendar lanes (e.g. "#3b82f6").
  color        String?
  isActive     Boolean  @default(true)
  linkedUserId String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  linkedUser User?     @relation("TechnicianLinkedUser", fields: [linkedUserId], references: [id], onDelete: SetNull)
  jobs       Job[]
  timeOff    TimeOff[]
  recurringJobTemplates RecurringJobTemplate[]

  @@index([isActive])
  @@map("technicians")
}

model TimeOff {
  id           String   @id @default(cuid())
  technicianId String
  start        DateTime
  end          DateTime
  reason       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([technicianId, start])
  @@index([technicianId, end])
  @@index([technicianId, start, end])
  @@map("time_off")
}

model PricingRule {
  id             String   @id @default(cuid())
  name           String
  description    String?
  baseCalloutFee Decimal  @db.Decimal(12, 2)
  blockMinutes   Int
  blockRate      Decimal  @db.Decimal(12, 2)
  isDefault      Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  serviceAddons ServiceAddon[]
  jobs          Job[]          @relation("JobPricingRule")
  invoices      Invoice[]      @relation("InvoicePricingRule")

  @@index([isActive, isDefault])
  @@map("pricing_rules")
}

model ServiceAddon {
  id            String   @id @default(cuid())
  pricingRuleId String
  name          String
  description   String?
  price         Decimal  @db.Decimal(12, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pricingRule PricingRule @relation(fields: [pricingRuleId], references: [id], onDelete: Cascade)

  @@index([pricingRuleId])
  @@index([isActive])
  @@map("service_addons")
}

model Job {
  id                  String    @id @default(cuid())
  title               String
  description         String?
  customerId          String
  technicianId        String?
  pricingRuleId       String?
  createdByUserId     String
  status              JobStatus @default(NEW)
  scheduledStart      DateTime?
  scheduledEnd        DateTime?
  internalNotes       String?
  customerNotes       String?
  serviceAddressLine1 String?
  serviceAddressLine2 String?
  serviceSuburb       String?
  serviceState        String?
  servicePostcode     String?
  serviceCountry      String?
  recurringTemplateId String?
  recurrenceOccurrenceDate DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  technician  Technician?  @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  pricingRule PricingRule? @relation("JobPricingRule", fields: [pricingRuleId], references: [id], onDelete: SetNull)
  createdBy   User         @relation("JobCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  invoice     Invoice?
  recurringTemplate RecurringJobTemplate? @relation(fields: [recurringTemplateId], references: [id], onDelete: SetNull)
  recurringOccurrences RecurringJobOccurrence[]

  @@index([status])
  @@index([customerId])
  @@index([technicianId])
  @@index([scheduledStart])
  @@index([scheduledEnd])
  @@index([technicianId, scheduledStart])
  @@index([technicianId, scheduledStart, scheduledEnd])
  @@index([recurringTemplateId, recurrenceOccurrenceDate])
  @@map("jobs")
}

/// One invoice per job (MVP). `jobId` is unique for a 1:1 Job ↔ Invoice mapping.
model Invoice {
  id            String        @id @default(cuid())
  jobId         String        @unique
  pricingRuleId String?
  subtotal      Decimal       @default(0) @db.Decimal(12, 2)
  tax           Decimal       @default(0) @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @default(0) @db.Decimal(12, 2)
  status        InvoiceStatus @default(DRAFT)
  issuedAt      DateTime?
  dueAt         DateTime?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  job         Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  pricingRule PricingRule? @relation("InvoicePricingRule", fields: [pricingRuleId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([pricingRuleId])
  @@map("invoices")
}

model AutomationRule {
  id         String   @id @default(cuid())
  key        String   @unique
  name       String
  isEnabled  Boolean  @default(true)
  config     Json?
  lastRunAt  DateTime?
  nextRunAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  runLogs AutomationRunLog[]

  @@map("automation_rules")
}

model AutomationRunLog {
  id          String   @id @default(cuid())
  ruleId      String?
  taskKey     String
  status      String
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  result      Json?
  error       String?
  createdAt   DateTime @default(now())

  rule AutomationRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([taskKey, startedAt(sort: Desc)])
  @@index([ruleId, startedAt(sort: Desc)])
  @@map("automation_run_logs")
}

model AutomationEventLog {
  id         String   @id @default(cuid())
  eventKey   String   @unique
  eventType  String
  entityType String?
  entityId   String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([eventType, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@map("automation_event_logs")
}

model RecurringJobTemplate {
  id                String            @id @default(cuid())
  customerId        String
  title             String
  description       String?
  technicianId      String?
  durationMinutes   Int               @default(60)
  recurrencePattern RecurrencePattern
  startDate         DateTime
  endDate           DateTime?
  isActive          Boolean           @default(true)
  lastGeneratedAt   DateTime?
  nextRunAt         DateTime?
  createdByUserId   String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  technician Technician? @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  createdBy User @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  generatedJobs Job[]
  occurrences RecurringJobOccurrence[]

  @@index([isActive, nextRunAt])
  @@index([customerId])
  @@map("recurring_job_templates")
}

model RecurringJobOccurrence {
  id             String   @id @default(cuid())
  templateId     String
  occurrenceDate DateTime
  generatedJobId String?
  createdAt      DateTime @default(now())

  template RecurringJobTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  generatedJob Job? @relation(fields: [generatedJobId], references: [id], onDelete: SetNull)

  @@unique([templateId, occurrenceDate])
  @@index([occurrenceDate])
  @@map("recurring_job_occurrences")
}
