# Runtime
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/technician_crm?schema=public"

# Auth
JWT_SECRET="replace-me"
JWT_REFRESH_SECRET="replace-me-too"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Billing
INVOICE_TAX_RATE_PERCENT=0

# Security / HTTP
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_JSON_LIMIT=1mb
TRUST_PROXY=false
ENABLE_DEV_TEST_ENDPOINTS=false
ENABLE_MANUAL_AUTOMATION_RUN=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_SENSITIVE_MAX=10
